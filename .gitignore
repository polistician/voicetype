# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build outputs (PyInstaller writes intermediates to build/<spec_name>/ — keep
# our source scripts at build/*.sh, *.spec, *.json tracked)
build/*
!build/*.sh
!build/*.spec
!build/*.json
!build/*.md
!build/*.command
dist/
*.dmg
*.dmg.sha256
*.icns
assets/app-icon.iconset/

# Models (downloaded at install/build time, not source)
models/

# Compiled Swift binaries at repo root (sources are tracked, binaries are not)
hotkey_helper
paste_helper
keys_helper
onboarding
settings_window
snippet_overlay
voicetype_launcher

# Bundle is a build artifact, not source
VoxType.app/
VoiceType.app/

# Brainstorming/plan working dir
.superpowers/

# OS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Local config you don't want to publish
.env

# WhisperKit Swift Package build artifacts + downloaded CoreML model bundle.
# Source files (Package.swift + Sources/) ARE tracked; only the .build dir
# and the model itself are too big / regenerable to commit.
build/whisperkit-helper/.build/
build/whisperkit-helper/.swiftpm/
build/whisperkit-helper/Package.resolved
models/whisperkit/
whisperkit_helper
